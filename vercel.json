{
  "version": 2,
  "functions": {
    "api/**/*.py": {
      "excludeFiles": "{node_modules/**,tests/**,static/**,assets/**,*.md}"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/server.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

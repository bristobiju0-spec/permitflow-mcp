{
  "version": 2,
  "functions": {
    "api/**/*.py": {
      "excludeFiles": "{node_modules/**,venv/**,public/**,src/**,build/**,dist/**,tests/**,*.md}"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/server.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
